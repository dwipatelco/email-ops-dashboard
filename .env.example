DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monitor_email
NEXT_PUBLIC_APP_NAME=Mail Monitor
# Production runtime must use real non-placeholder secrets.
APP_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
SESSION_SECRET=replace-with-strong-session-secret
SYNC_POLL_INTERVAL_MS=60000
EVENTS_POLL_INTERVAL_MS=3000
